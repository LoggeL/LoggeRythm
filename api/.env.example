# Copy to .env and fill in. NEVER commit the real .env.
DEEZER_ARL=your_deezer_arl_cookie_here
DEEZER_QUALITY=mp3
STORAGE_DIR=storage
DATABASE_URL=sqlite:///./spotifrei.db
APP_ENV=development
JWT_SECRET=change-me-in-production
# Set to true when serving over HTTPS in production
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Spotify link resolution (Client Credentials). Create an app at
# https://developer.spotify.com/dashboard to get these. Playback still via Deezer.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_RESOLVE_LIMIT=200

# Last.fm — external song-similarity source for the radio (optional; free key at
# https://www.last.fm/api/account/create). Without it the radio uses Deezer's mix.
LASTFM_API_KEY=

# Groq lyrics transcription fallback (optional). Never commit a real key.
GROQ_API_KEY=
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo
