+package com.doublesymmetry.trackplayer.models
+
+import android.os.Bundle
+import androidx.media3.common.Player
+import androidx.media3.exoplayer.ExoPlayer
+import com.doublesymmetry.trackplayer.TrackPlayerModule.Companion.PLAYER_PREFS_NAME
+import org.junit.After
+import org.junit.Assert.assertEquals
+import org.junit.Assert.assertFalse
+import org.junit.Assert.assertNotNull
+import org.junit.Assert.assertNull
+import org.junit.Assert.assertTrue
+import org.junit.Before
+import org.junit.Test
+import org.junit.runner.RunWith
+import org.robolectric.RobolectricTestRunner
+import org.robolectric.RuntimeEnvironment
+import org.robolectric.annotation.Config
+import javax.crypto.KeyGenerator
+import javax.crypto.SecretKey
+
+@RunWith(RobolectricTestRunner::class)
+@Config(sdk = [33])
+class PlayerStateTest {
+  private val context get() = RuntimeEnvironment.getApplication()
+  private lateinit var key: SecretKey
+  private lateinit var storage: PlayerStateStorage
+  private var players = mutableListOf<ExoPlayer>()
+
+  @Before
+  fun setUp() {
+    key = KeyGenerator.getInstance("AES").apply { init(256) }.generateKey()
+    storage = PlayerStateStorage(encryptionKey = { key }, decryptionKey = { key })
+    context.getSharedPreferences(PLAYER_PREFS_NAME, 0).edit().clear().commit()
+    MediaHeaders.clear()
+  }
+
+  @After
+  fun tearDown() {
+    players.forEach(ExoPlayer::release)
+    players.clear()
+    MediaHeaders.clear()
+  }
+
+  private fun player(): ExoPlayer = ExoPlayer.Builder(context).build().also(players::add)
+
+  private fun mediaItem(
+    mediaId: String,
+    cookie: String,
+    origin: String,
+    order: Double? = null,
+  ) = TrackPlayerMediaItem(
+    mediaId = mediaId,
+    url = "https://example.com/$mediaId.mp3",
+    title = "Track $mediaId",
+    artist = "Persistence Artist",
+    duration = 180.0,
+    headers = mapOf("Cookie" to cookie),
+    extras = Bundle().apply {
+      putString("queueOrigin", origin)
+      putString("queueContextType", "playlist")
+      putString("queueContextId", "playlist-1")
+      order?.let { putDouble("queueOriginalContextOrder", it) }
+      putString("queueStableId", "stable:$mediaId")
+      putBundle("track", Bundle().apply {
+        putString("id", mediaId)
+        putString("title", "Track $mediaId")
+      })
+    },
+  ).asMediaItem(context)
+
+  @Test
+  fun `encrypted timeline round trip preserves queue metadata active position repeat and shuffle`() {
+    val original = player()
+    val activeCookie = "sf_session=secret-active-token"
+    val queue = listOf(
+      mediaItem("history", "sf_session=history-token", "context", 0.0),
+      mediaItem("active", activeCookie, "context", 1.0),
+      mediaItem("manual", "sf_session=manual-token", "manual"),
+      mediaItem("future", "sf_session=future-token", "context", 2.0),
+    )
+    original.setMediaItems(queue, 1, 42_125L)
+    original.repeatMode = Player.REPEAT_MODE_ALL
+    original.shuffleModeEnabled = false
+    val restoreOrder = listOf("stable:future")
+    PlayerStateRegistry.updateQueuePersistence(
+      context,
+      QueuePersistenceState(true, restoreOrder),
+      storage,
+    )
+
+    PlayerStateRegistry.persist(context, original, storage)
+
+    val encoded = context.getSharedPreferences(PLAYER_PREFS_NAME, 0)
+      .getString(PLAYER_STATE_KEY, null)
+    assertNotNull(encoded)
+    assertTrue(encoded!!.startsWith("aes-gcm-v1:"))
+    assertFalse(encoded.contains(activeCookie))
+    assertFalse(encoded.contains("stable:future"))
+
+    MediaHeaders.clearPlayer()
+    val restored = player()
+    assertTrue(PlayerStateRegistry.restoreOrClear(context, restored, storage))
+
+    assertEquals(4, restored.mediaItemCount)
+    assertEquals(1, restored.currentMediaItemIndex)
+    assertEquals(42_125L, restored.currentPosition)
+    assertEquals(Player.REPEAT_MODE_ALL, restored.repeatMode)
+    assertFalse(restored.shuffleModeEnabled)
+    assertFalse(restored.playWhenReady)
+
+    val active = TrackPlayerMediaItem.fromMediaItem(restored.getMediaItemAt(1))
+    assertEquals("stable:active", active.extras?.getString("queueStableId"))
+    assertEquals("context", active.extras?.getString("queueOrigin"))
+    assertEquals("playlist", active.extras?.getString("queueContextType"))
+    assertEquals("playlist-1", active.extras?.getString("queueContextId"))
+    assertEquals(1.0, active.extras?.getDouble("queueOriginalContextOrder"))
+    assertEquals("active", active.extras?.getBundle("track")?.getString("id"))
+    assertEquals(activeCookie, MediaHeaders.get(active.url)?.get("Cookie"))
+    assertEquals(
+      QueuePersistenceState(true, restoreOrder),
+      PlayerStateRegistry.getQueuePersistence(context, storage),
+    )
+  }
+
+  @Test
+  fun `encrypted restore preserves numeric-looking track identifiers as strings`() {
+    val trackId = "1483825282"
+    val original = player()
+    val trackExtras = Bundle().apply {
+      putString("id", trackId)
+      putString("title", "Numeric identifier")
+      putString("artist", "Persistence Artist")
+      putString("artist_id", "123456")
+      putString("album_id", "987654")
+      putSerializable(
+        "artists",
+        arrayListOf(Bundle().apply {
+          putString("id", "123456")
+          putString("name", "Persistence Artist")
+        }),
+      )
+    }
+    val item = TrackPlayerMediaItem(
+      mediaId = "queue:2:0:$trackId",
+      url = "https://example.com/$trackId.mp3",
+      title = "Numeric identifier",
+      artist = "Persistence Artist",
+      headers = mapOf("Cookie" to "sf_session=token"),
+      extras = Bundle().apply { putBundle("track", trackExtras) },
+    ).asMediaItem(context)
+    original.setMediaItem(item)
+
+    PlayerStateRegistry.persist(context, original, storage)
+
+    val restored = player()
+    assertTrue(PlayerStateRegistry.restoreOrClear(context, restored, storage))
+    val restoredTrack = TrackPlayerMediaItem
+      .fromMediaItem(restored.currentMediaItem!!)
+      .extras
+      ?.getBundle("track")
+    assertNotNull(restoredTrack)
+    assertEquals(trackId, restoredTrack!!.getString("id"))
+    assertEquals("123456", restoredTrack.getString("artist_id"))
+    assertEquals("987654", restoredTrack.getString("album_id"))
+
+    @Suppress("DEPRECATION")
+    val restoredArtists = restoredTrack.getSerializable("artists") as? ArrayList<*>
+    assertNotNull(restoredArtists)
+    val restoredArtist = restoredArtists!![0] as Bundle
+    assertEquals("123456", restoredArtist.getString("id"))
+  }
+
+  @Test
+  fun `persisting an empty queue deletes account scoped queue and product shuffle state`() {
+    val original = player()
+    original.setMediaItem(mediaItem("active", "sf_session=token", "context", 0.0))
+    PlayerStateRegistry.updateQueuePersistence(
+      context,
+      QueuePersistenceState(true, listOf("stable:active")),
+      storage,
+    )
+    PlayerStateRegistry.persist(context, original, storage)
+    assertNotNull(storage.load(context))
+
+    original.clearMediaItems()
+    PlayerStateRegistry.persist(context, original, storage)
+
+    assertNull(storage.load(context))
+    assertEquals(
+      QueuePersistenceState(),
+      PlayerStateRegistry.getQueuePersistence(context, storage),
+    )
+    assertNull(MediaHeaders.get("https://example.com/active.mp3"))
+  }
+
+  @Test
+  fun `corrupt or plaintext state is discarded without populating the player`() {
+    val prefs = context.getSharedPreferences(PLAYER_PREFS_NAME, 0)
+    prefs.edit().putString(
+      PLAYER_STATE_KEY,
+      "{\"headers\":{\"Cookie\":\"sf_session=plaintext\"}}",
+    ).commit()
+    val restored = player()
+
+    assertFalse(PlayerStateRegistry.restoreOrClear(context, restored, storage))
+
+    assertEquals(0, restored.mediaItemCount)
+    assertNull(prefs.getString(PLAYER_STATE_KEY, null))
+  }
+}
