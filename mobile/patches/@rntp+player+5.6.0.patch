+ */
+
+package com.doublesymmetry.trackplayer
+
+/** Pure policy kept separate from Media3 so controller authorization is unit-testable. */
+internal object MediaControllerTrustPolicy {
+  fun canConnect(
+    appUid: Int,
+    controllerUid: Int,
+    isTrusted: Boolean,
+  ): Boolean = isTrusted || controllerUid == appUid
+
+  fun canUsePrivilegedCommands(
+    appUid: Int,
+    controllerUid: Int,
+  ): Boolean = controllerUid == appUid
+}
