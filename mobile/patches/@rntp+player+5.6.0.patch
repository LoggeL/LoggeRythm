+internal data class PersistedPlayerMediaItem(
+  val mediaId: String,
+  val url: String,
+  val title: String? = null,
+  val artist: String? = null,
+  val albumTitle: String? = null,
+  val artworkUrl: String? = null,
+  val duration: Double? = null,
+  val isLive: Boolean? = null,
+  val mimeType: String? = null,
+  val headers: Map<String, String>? = null,
+  val extras: JsonObject? = null,
+) {
+  fun validated(): PersistedPlayerMediaItem {
+    require(mediaId.isNotBlank()) { "Persisted player mediaId must not be blank" }
+    require(url.isNotBlank()) { "Persisted player URL must not be blank" }
+    headers?.keys?.forEach { key ->
+      require(key.isNotBlank()) { "Persisted player header names must not be blank" }
+    }
+    return this
+  }
+
+  fun toMediaItem(context: Context): MediaItem = TrackPlayerMediaItem(
+    mediaId = mediaId,
+    url = url,
+    title = title,
+    artist = artist,
+    albumTitle = albumTitle,
+    artworkUrl = artworkUrl,
+    duration = duration,
+    isLive = isLive,
+    mimeType = mimeType,
+    headers = headers,
+    extras = extras?.let(MediaItemExtras::jsonToBundle),
+  ).asMediaItem(context)
+
+  companion object {
+    fun fromMediaItem(item: MediaItem): PersistedPlayerMediaItem {
+      val descriptor = TrackPlayerMediaItem.fromMediaItem(item)
+      val url = descriptor.url
+      return PersistedPlayerMediaItem(
+        mediaId = item.mediaId,
+        url = url,
+        title = descriptor.title,
+        artist = descriptor.artist,
+        albumTitle = descriptor.albumTitle,
+        artworkUrl = descriptor.artworkUrl,
+        duration = descriptor.duration,
+        isLive = descriptor.isLive,
+        mimeType = item.localConfiguration?.mimeType,
+        headers = MediaHeaders.get(url)?.toMap(),
+        extras = descriptor.extras?.let(MediaItemExtras::bundleToJsonObject),
+      ).validated()
+    }
+  }
+}
+
+@Serializable
+internal data class PersistedPlayerState(
+  val version: Int = PLAYER_STATE_VERSION,
+  val items: List<PersistedPlayerMediaItem>,
+  val activeIndex: Int,
+  val positionMs: Long,
+  val repeatMode: Int,
+  val shuffleEnabled: Boolean,
+  val queuePersistence: QueuePersistenceState = QueuePersistenceState(),
+) {
+  fun validated(): PersistedPlayerState {
+    require(version == PLAYER_STATE_VERSION) {
+      "Unsupported persisted player-state version $version"
+    }
+    require(items.isNotEmpty()) { "Persisted player state must contain at least one item" }
+    items.forEach(PersistedPlayerMediaItem::validated)
+    require(activeIndex in items.indices) {
+      "Persisted active index $activeIndex is outside a ${items.size}-item queue"
+    }
+    require(positionMs >= 0L) { "Persisted player position must not be negative" }
+    require(
+      repeatMode == Player.REPEAT_MODE_OFF ||
+        repeatMode == Player.REPEAT_MODE_ONE ||
+        repeatMode == Player.REPEAT_MODE_ALL,
+    ) { "Persisted repeat mode $repeatMode is invalid" }
+    queuePersistence.validated()
+    return this
+  }
+
+  companion object {
+    fun capture(player: Player, queuePersistence: QueuePersistenceState): PersistedPlayerState {
+      require(player.mediaItemCount > 0) { "Cannot persist an empty player queue" }
+      val activeIndex = player.currentMediaItemIndex
+      require(activeIndex in 0 until player.mediaItemCount) {
+        "Cannot persist active index $activeIndex for a ${player.mediaItemCount}-item queue"
+      }
+      val items = (0 until player.mediaItemCount).map { index ->
+        PersistedPlayerMediaItem.fromMediaItem(player.getMediaItemAt(index))
+      }
+      return PersistedPlayerState(
+        items = items,
+        activeIndex = activeIndex,
+        positionMs = player.currentPosition.coerceAtLeast(0L),
+        repeatMode = player.repeatMode,
+        shuffleEnabled = player.shuffleModeEnabled,
+        queuePersistence = queuePersistence.validated(),
+      ).validated()
+    }
+  }
+}
+
+private object AndroidPlayerStateKey {
+  private fun keyStore(): KeyStore = KeyStore.getInstance(ANDROID_KEYSTORE).apply { load(null) }
+
+  @Synchronized
+  fun requireExisting(): SecretKey {
+    val entry = keyStore().getEntry(PLAYER_STATE_KEY_ALIAS, null)
+      ?: throw IllegalStateException(
+        "Player-state encryption key '$PLAYER_STATE_KEY_ALIAS' is missing",
+      )
+    if (entry !is KeyStore.SecretKeyEntry) {
+      throw IllegalStateException(
+        "Player-state key '$PLAYER_STATE_KEY_ALIAS' has unexpected type ${entry::class.java.name}",
+      )
+    }
+    return entry.secretKey
+  }
+
+  @Synchronized
+  fun getOrCreate(): SecretKey {
+    val store = keyStore()
+    val existing = store.getEntry(PLAYER_STATE_KEY_ALIAS, null)
+    if (existing != null) {
+      if (existing !is KeyStore.SecretKeyEntry) {
+        throw IllegalStateException(
+          "Player-state key '$PLAYER_STATE_KEY_ALIAS' has unexpected type " +
+            existing::class.java.name,
+        )
+      }
+      return existing.secretKey
+    }
+
+    val generator = KeyGenerator.getInstance(KeyProperties.KEY_ALGORITHM_AES, ANDROID_KEYSTORE)
+    generator.init(
+      KeyGenParameterSpec.Builder(
+        PLAYER_STATE_KEY_ALIAS,
+        KeyProperties.PURPOSE_ENCRYPT or KeyProperties.PURPOSE_DECRYPT,
+      )
+        .setBlockModes(KeyProperties.BLOCK_MODE_GCM)
+        .setEncryptionPaddings(KeyProperties.ENCRYPTION_PADDING_NONE)
+        .setKeySize(256)
+        .build(),
+    )
+    return generator.generateKey()
+  }
+}
+
+internal class PlayerStateStorage(
+  private val encryptionKey: () -> SecretKey = { AndroidPlayerStateKey.getOrCreate() },
+  private val decryptionKey: () -> SecretKey = { AndroidPlayerStateKey.requireExisting() },
+) {
+  fun store(context: Context, state: PersistedPlayerState) {
+    val validated = state.validated()
+    val encoded = try {
+      val plaintext = PLAYER_STATE_JSON.encodeToString(validated)
+        .toByteArray(StandardCharsets.UTF_8)
+      val cipher = Cipher.getInstance(AES_GCM)
+      cipher.init(Cipher.ENCRYPT_MODE, encryptionKey())
+      cipher.updateAAD(PLAYER_STATE_AAD)
+      val ciphertext = cipher.doFinal(plaintext)
+      listOf(
+        ENCRYPTED_PREFIX,
+        Base64.encodeToString(cipher.iv, Base64.NO_WRAP),
+        Base64.encodeToString(ciphertext, Base64.NO_WRAP),
+      ).joinToString(":")
+    } catch (cause: Exception) {
+      throw IllegalStateException("Player state could not be encrypted: ${cause.message}", cause)
+    }
+    val prefs = context.getSharedPreferences(PLAYER_PREFS_NAME, Context.MODE_PRIVATE)
+    if (!prefs.edit().putString(PLAYER_STATE_KEY, encoded).commit()) {
+      throw IllegalStateException("Failed to persist encrypted player state")
+    }
+  }
+
+  fun load(context: Context): PersistedPlayerState? {
+    val prefs = context.getSharedPreferences(PLAYER_PREFS_NAME, Context.MODE_PRIVATE)
+    val encoded = prefs.getString(PLAYER_STATE_KEY, null) ?: return null
+    val parts = encoded.split(':')
+    if (parts.size != 3 || parts[0] != ENCRYPTED_PREFIX) {
+      throw IllegalStateException("Stored player state has an unsupported encrypted format")
+    }
+    val plaintext = try {
+      val iv = Base64.decode(parts[1], Base64.NO_WRAP)
+      val ciphertext = Base64.decode(parts[2], Base64.NO_WRAP)
+      val cipher = Cipher.getInstance(AES_GCM)
+      cipher.init(Cipher.DECRYPT_MODE, decryptionKey(), GCMParameterSpec(128, iv))
+      cipher.updateAAD(PLAYER_STATE_AAD)
+      String(cipher.doFinal(ciphertext), StandardCharsets.UTF_8)
+    } catch (cause: Exception) {
+      throw IllegalStateException("Stored player state could not be decrypted: ${cause.message}", cause)
+    }
+    return try {
+      PLAYER_STATE_JSON.decodeFromString<PersistedPlayerState>(plaintext).validated()
+    } catch (cause: Exception) {
+      throw IllegalStateException("Stored decrypted player state is invalid: ${cause.message}", cause)
+    }
+  }
+
+  fun clear(context: Context) {
+    val prefs = context.getSharedPreferences(PLAYER_PREFS_NAME, Context.MODE_PRIVATE)
+    if (!prefs.edit().remove(PLAYER_STATE_KEY).commit()) {
+      throw IllegalStateException("Failed to delete persisted player state")
+    }
+  }
+}
+
+/**
+ * Owns the encrypted timeline snapshot and the product queue state that Media3 cannot express
+ * (manual/context shuffle uses physical moves while native global shuffle remains disabled).
+ */
+internal object PlayerStateRegistry {
+  private var queuePersistence = QueuePersistenceState()
+  private var initialized = false
+
+  @Synchronized
+  fun restoreOrClear(
+    context: Context,
+    player: Player,
+    storage: PlayerStateStorage = PlayerStateStorage(),
+  ): Boolean {
+    MediaHeaders.clearPlayer()
+    return try {
+      val state = storage.load(context)
+      if (state == null) {
+        queuePersistence = QueuePersistenceState()
+        initialized = true
+        false
+      } else {
+        queuePersistence = state.queuePersistence.validated()
+        initialized = true
+        val restoredItems = state.items.map { it.toMediaItem(context) }
+        player.setMediaItems(restoredItems, state.activeIndex, state.positionMs)
+        player.repeatMode = state.repeatMode
+        player.shuffleModeEnabled = state.shuffleEnabled
+        // A process restart restores intent and position, never unsolicited playback.
+        player.pause()
+        true
+      }
+    } catch (cause: Exception) {
+      MediaHeaders.clearPlayer()
+      queuePersistence = QueuePersistenceState()
+      initialized = true
+      try {
+        storage.clear(context)
+      } catch (cleanupCause: Exception) {
+        cause.addSuppressed(cleanupCause)
+      }
+      Log.e("TrackPlayer", "Discarded invalid persisted player state", cause)
+      false
+    }
+  }
+
+  @Synchronized
+  fun persist(
+    context: Context,
+    player: Player,
+    storage: PlayerStateStorage = PlayerStateStorage(),
+  ) {
+    if (player.mediaItemCount == 0) {
+      storage.clear(context)
+      MediaHeaders.clearPlayer()
+      queuePersistence = QueuePersistenceState()
+      initialized = true
+      return
+    }
+    storage.store(context, PersistedPlayerState.capture(player, queuePersistence))
+    initialized = true
+  }
+
+  @Synchronized
+  fun updateQueuePersistence(
+    context: Context,
+    next: QueuePersistenceState,
+    storage: PlayerStateStorage = PlayerStateStorage(),
+  ) {
+    val validated = next.validated()
+    queuePersistence = validated
+    initialized = true
+    val existing = storage.load(context) ?: return
+    storage.store(context, existing.copy(queuePersistence = validated))
+  }
+
+  @Synchronized
+  fun getQueuePersistence(
+    context: Context,
+    storage: PlayerStateStorage = PlayerStateStorage(),
+  ): QueuePersistenceState {
+    if (!initialized) {
+      queuePersistence = storage.load(context)?.queuePersistence?.validated()
+        ?: QueuePersistenceState()
+      initialized = true
+    }
+    return queuePersistence
+  }
+
+  @Synchronized
+  fun clear(
+    context: Context,
+    storage: PlayerStateStorage = PlayerStateStorage(),
+  ) {
+    storage.clear(context)
+    MediaHeaders.clearPlayer()
+    queuePersistence = QueuePersistenceState()
+    initialized = true
+  }
+}
