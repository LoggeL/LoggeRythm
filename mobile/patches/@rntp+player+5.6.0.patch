+/*
+ * Copyright (c) Double Symmetry GmbH
+ * Commercial use requires a license. See https://rntp.dev/pricing
+ */
+
+package com.doublesymmetry.trackplayer
+
+import androidx.annotation.OptIn
+import androidx.media3.common.util.UnstableApi
+import androidx.media3.datasource.cache.Cache
+import java.io.File
+
+/** Synchronous cache eviction used by account cleanup's awaitable native command. */
+internal object AutomaticAudioCacheEviction {
+  @OptIn(UnstableApi::class)
+  fun clear(cache: Cache): Int {
+    val keys = cache.keys.toList()
+    keys.forEach(cache::removeResource)
+
+    val remaining = cache.keys.toList()
+    check(remaining.isEmpty()) {
+      "Automatic audio cache eviction left ${remaining.size} resource(s) behind"
+    }
+    return keys.size
+  }
+
+  /** A cache-disabled service may still inherit an old directory from an earlier configuration. */
+  fun clearInactiveDirectory(directory: File) {
+    if (!directory.exists()) return
+    check(directory.deleteRecursively() && !directory.exists()) {
+      "Automatic audio cache directory could not be removed"
+    }
+  }
+}
