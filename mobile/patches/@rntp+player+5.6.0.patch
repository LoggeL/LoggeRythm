+  private fun decodeJson(value: String, source: String): BrowseTree = try {
+    Json.decodeFromString(value)
+  } catch (cause: Exception) {
+    throw IllegalStateException(
+      "Stored $source Android Auto browse tree is invalid: ${cause.message}",
+      cause,
+    )
+  }
+}
+
+internal object BrowseTreeRegistry {
+  @Synchronized
+  fun store(context: Context, tree: BrowseTree, storage: BrowseTreeStorage) {
+    try {
+      val headers = tree.headerSnapshot(context)
+      storage.store(context, tree)
+      MediaHeaders.replaceBrowse(headers)
+    } catch (cause: Exception) {
+      MediaHeaders.clearBrowse()
+      try {
+        storage.clear(context)
+      } catch (cleanupCause: Exception) {
+        cause.addSuppressed(cleanupCause)
+      }
+      throw cause
+    }
+  }
+
+  @Synchronized
+  fun load(context: Context, storage: BrowseTreeStorage): BrowseTree {
+    try {
+      val tree = storage.load(context)
+      MediaHeaders.replaceBrowse(tree.headerSnapshot(context))
+      return tree
+    } catch (cause: Exception) {
+      MediaHeaders.clearBrowse()
+      throw cause
+    }
+  }
+
+  @Synchronized
+  fun clear(context: Context, storage: BrowseTreeStorage) {
+    // Headers contain the account credential. Remove them even if durable
+    // preference deletion fails so the live process cannot reuse old auth.
+    MediaHeaders.clearBrowse()
+    storage.clear(context)
+  }
