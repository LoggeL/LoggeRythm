+  @Test
+  fun trustedSystemControllerIsAllowedWithoutPrivilegedAppCommands() {
+    assertTrue(
+      MediaControllerTrustPolicy.canConnect(
+        appUid,
+        controllerUid = 1_000,
+        isTrusted = true,
+      )
+    )
+    assertFalse(
+      MediaControllerTrustPolicy.canUsePrivilegedCommands(
+        appUid,
+        controllerUid = 1_000,
