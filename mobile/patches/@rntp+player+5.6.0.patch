+package com.doublesymmetry.trackplayer.models
+
+import androidx.test.core.app.ApplicationProvider
+import androidx.test.ext.junit.runners.AndroidJUnit4
+import com.doublesymmetry.trackplayer.TrackPlayerModule.Companion.PLAYER_PREFS_NAME
+import org.junit.Assert.assertEquals
+import org.junit.Assert.assertFalse
+import org.junit.Assert.assertNotNull
+import org.junit.Assert.assertTrue
+import org.junit.Test
+import org.junit.runner.RunWith
+
+@RunWith(AndroidJUnit4::class)
+class BrowseTreeStorageInstrumentedTest {
+  @Test
+  fun androidKeystoreRoundTripRestoresAuthenticatedBrowseHeaders() {
+    val context = ApplicationProvider.getApplicationContext<android.content.Context>()
+    val prefs = context.getSharedPreferences(PLAYER_PREFS_NAME, android.content.Context.MODE_PRIVATE)
+    assertTrue("Could not clear TrackPlayer test preferences", prefs.edit().clear().commit())
+
+    val uri = "https://example.com/secure.mp3"
+    val tree = BrowseTree(
+      listOf(
+        BrowseCategory(
+          mediaId = "cat-1",
+          title = "Music",
+          items = listOf(
+            BrowseMediaItem(
+              mediaId = "t1",
+              url = uri,
+              headers = mapOf("Cookie" to "sf_session=instrumented-token"),
+              title = "Track 1",
+            ),
+          ),
+        ),
+      ),
+    )
+
+    tree.store(context)
+    val persisted = prefs.getString("browse_tree", null)
+    assertNotNull(persisted)
+    assertTrue(persisted!!.startsWith("aes-gcm-v1:"))
+    assertFalse(persisted.contains("sf_session=instrumented-token"))
+
+    MediaHeaders.clearBrowse()
+    val restored = BrowseTree.load(context)
+
+    assertEquals(uri, restored.categories.single().items.single().url)
+    assertEquals("sf_session=instrumented-token", MediaHeaders.get(uri)?.get("Cookie"))
+  }
+}
