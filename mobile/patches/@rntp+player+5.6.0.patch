+package com.doublesymmetry.trackplayer
+
+import org.junit.Assert.assertEquals
+import org.junit.Assert.assertNull
+import org.junit.Assert.assertSame
+import org.junit.Assert.assertThrows
+import org.junit.Assert.assertTrue
+import org.junit.Test
+
+class MainThreadMediaControllerTest {
+  @Test
+  fun queuedOperationsFlushInSubmissionOrder() {
+    val queue = ControllerOperationQueue<String>()
+    val calls = mutableListOf<String>()
+
+    queue.beginConnection()
+    queue.run { controller ->
+      calls += "first:$controller"
+      queue.run { calls += "third:$it" }
+    }
+    queue.run { calls += "second:$it" }
+
+    assertNull(queue.controllerForSynchronousRead())
+    queue.connect("connected")
+
+    assertEquals(
+      listOf("first:connected", "second:connected", "third:connected"),
+      calls,
+    )
+  }
+
+  @Test
+  fun operationBeforeSetupFailsClearly() {
+    val error = assertThrows(IllegalStateException::class.java) {
+      ControllerOperationQueue<String>().run { }
+    }
+
+    assertTrue(error.message.orEmpty().contains("setupPlayer"))
+  }
+
+  @Test
+  fun persistedStateNotificationBeforeSetupIsAnExplicitNonOperation() {
+    val queue = ControllerOperationQueue<String>()
+    var called = false
+
+    val accepted = queue.runIfConnectingOrConnected { called = true }
+
+    assertEquals(false, accepted)
+    assertEquals(false, called)
+  }
+
+  @Test
+  fun repeatedConnectionAttemptFailsClearly() {
+    val queue = ControllerOperationQueue<String>()
+    queue.beginConnection()
+
+    val connectingError = assertThrows(IllegalStateException::class.java) {
+      queue.beginConnection()
+    }
+    assertTrue(connectingError.message.orEmpty().contains("already in progress"))
+
+    queue.connect("connected")
+    val connectedError = assertThrows(IllegalStateException::class.java) {
+      queue.beginConnection()
+    }
+    assertTrue(connectedError.message.orEmpty().contains("already connected"))
+  }
+
+  @Test
+  fun disconnectedOperationsFailAndExplicitReconnectSucceeds() {
+    val queue = ControllerOperationQueue<String>()
+    queue.beginConnection()
+    queue.connect("first")
+    queue.disconnect()
+
+    val error = assertThrows(IllegalStateException::class.java) {
+      queue.run { }
+    }
+    assertTrue(error.message.orEmpty().contains("disconnected"))
+
+    queue.beginConnection()
+    queue.connect("second")
+    assertEquals("second", queue.controllerForSynchronousRead())
+  }
+
+  @Test
+  fun destroyQueuedWhileConnectingDisconnectsDuringOrderedFlush() {
+    val queue = ControllerOperationQueue<String>()
+    val calls = mutableListOf<String>()
+    queue.beginConnection()
+    queue.run { calls += "before-destroy:$it" }
+    queue.runAndDisconnect {
+      calls += "destroy:$it"
+    }
+
+    val rejectedAfterDestroy = assertThrows(IllegalStateException::class.java) {
+      queue.run { calls += "after-destroy:$it" }
+    }
+    assertTrue(rejectedAfterDestroy.message.orEmpty().contains("disconnect is in progress"))
+
+    queue.connect("connected")
+
+    assertEquals(listOf("before-destroy:connected", "destroy:connected"), calls)
+    val disconnectedError = assertThrows(IllegalStateException::class.java) {
+      queue.run { calls += "after-disconnect:$it" }
+    }
+    assertTrue(disconnectedError.message.orEmpty().contains("disconnected"))
+  }
+
+  @Test
+  fun connectionFailureIsRetainedAsTheActionableCause() {
+    val queue = ControllerOperationQueue<String>()
+    val cause = SecurityException("session rejected")
+    queue.beginConnection()
+    queue.fail(cause)
+
+    val error = assertThrows(IllegalStateException::class.java) {
+      queue.run { }
+    }
+
+    assertSame(cause, error.cause)
+    assertTrue(error.message.orEmpty().contains("connection failed"))
+  }
+
+  @Test
+  fun failedConnectionCanBeRetriedAndPublishesOnlyTheReplacementController() {
+    val queue = ControllerOperationQueue<String>()
+    val calls = mutableListOf<String>()
+    queue.beginConnection()
+    queue.run { calls += "stale:$it" }
+    queue.fail(SecurityException("session rejected"))
+
+    queue.beginConnection()
+    queue.run { calls += "retry:$it" }
+    assertNull(queue.controllerForSynchronousRead())
+    queue.connect("connected-after-retry")
+
+    assertEquals(listOf("retry:connected-after-retry"), calls)
+    assertEquals("connected-after-retry", queue.controllerForSynchronousRead())
+  }
+}
