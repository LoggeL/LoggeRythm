+/*
+ * Copyright (c) Double Symmetry GmbH
+ * Commercial use requires a license. See https://rntp.dev/pricing
+ */
+
+package com.doublesymmetry.trackplayer
+
+import java.util.ArrayDeque
+
+/** Thread-safe lifecycle and FIFO queue used while a MediaController connection is pending. */
+internal class ControllerOperationQueue<T>(
+  private val execute: (T, (T) -> Unit) -> Unit = { controller, operation ->
+    operation(controller)
+  }
+) {
+  private enum class State {
+    NOT_STARTED,
+    CONNECTING,
+    FLUSHING,
+    CONNECTED,
+    DISCONNECTED,
+    FAILED,
+  }
+
+  private var state = State.NOT_STARTED
+  private var controller: T? = null
+  private var connectionFailure: Throwable? = null
+  private var disconnectRequested = false
+  private val pendingOperations = ArrayDeque<(T) -> Unit>()
+
+  @Synchronized
+  fun beginConnection() {
+    check(state == State.NOT_STARTED || state == State.DISCONNECTED || state == State.FAILED) {
+      when (state) {
+        State.CONNECTING, State.FLUSHING ->
+          "MediaController connection is already in progress"
+        State.CONNECTED ->
+          "MediaController is already connected; call destroy() before setupPlayer() again"
+        else -> "MediaController cannot start a connection from state $state"
+      }
+    }
+
+    controller = null
+    connectionFailure = null
+    disconnectRequested = false
+    pendingOperations.clear()
+    state = State.CONNECTING
+  }
+
+  fun run(operation: (T) -> Unit) {
+    val connectedController: T
+    synchronized(this) {
+      check(!disconnectRequested) {
+        "MediaController disconnect is in progress; call setupPlayer() after destroy completes"
+      }
+      when (state) {
+        State.CONNECTING, State.FLUSHING -> {
+          pendingOperations.addLast(operation)
+          return
+        }
+        State.CONNECTED -> connectedController = checkNotNull(controller)
+        State.NOT_STARTED -> throw IllegalStateException(
+          "MediaController is not initialized; call setupPlayer() first"
+        )
+        State.DISCONNECTED -> throw IllegalStateException(
+          "MediaController is disconnected; call setupPlayer() before using the player"
+        )
+        State.FAILED -> throw IllegalStateException(
+          "MediaController connection failed; call setupPlayer() to retry",
+          connectionFailure,
+        )
+      }
+    }
+
+    execute(connectedController, operation)
+  }
+
+  /**
+   * Runs or queues a best-effort notification, returning false when no connection lifecycle
+   * exists. This is reserved for state that has already been persisted independently.
+   */
+  fun runIfConnectingOrConnected(operation: (T) -> Unit): Boolean {
+    val connectedController: T
+    synchronized(this) {
+      if (disconnectRequested) return false
+      when (state) {
+        State.CONNECTING, State.FLUSHING -> {
+          pendingOperations.addLast(operation)
+          return true
+        }
+        State.CONNECTED -> connectedController = checkNotNull(controller)
+        State.NOT_STARTED, State.DISCONNECTED, State.FAILED -> return false
+      }
+    }
+
+    execute(connectedController, operation)
+    return true
+  }
+
+  fun runAndDisconnect(operation: (T) -> Unit) {
+    val connectedController: T
+    synchronized(this) {
+      check(!disconnectRequested) { "MediaController disconnect is already in progress" }
+
+      when (state) {
+        State.CONNECTING, State.FLUSHING -> {
+          disconnectRequested = true
+          pendingOperations.addLast { queuedController ->
+            try {
+              operation(queuedController)
+            } finally {
+              disconnect()
+            }
+          }
+          return
+        }
+        State.CONNECTED -> {
+          disconnectRequested = true
+          connectedController = checkNotNull(controller)
+        }
+        State.NOT_STARTED -> throw IllegalStateException(
+          "MediaController is not initialized; call setupPlayer() first"
+        )
+        State.DISCONNECTED -> throw IllegalStateException("MediaController is already disconnected")
+        State.FAILED -> throw IllegalStateException(
+          "MediaController connection failed; there is no connected controller to destroy",
+          connectionFailure,
+        )
+      }
+    }
+
+    execute(connectedController) { activeController ->
+      try {
+        operation(activeController)
+      } finally {
+        disconnect()
+      }
+    }
+  }
+
+  fun connect(newController: T) {
+    synchronized(this) {
+      check(state == State.CONNECTING) {
+        "MediaController completed a connection from invalid state $state"
+      }
+      controller = newController
+      state = State.FLUSHING
+    }
+
+    try {
+      while (true) {
+        val operation = synchronized(this) {
+          if (state != State.FLUSHING) return
+          if (pendingOperations.isEmpty()) {
+            state = State.CONNECTED
+            return
+          }
+          pendingOperations.removeFirst()
+        }
+        execute(newController, operation)
+      }
+    } catch (error: Throwable) {
+      fail(error)
+      throw error
+    }
+  }
+
+  @Synchronized
+  fun fail(error: Throwable) {
+    controller = null
+    connectionFailure = error
+    disconnectRequested = false
+    pendingOperations.clear()
+    state = State.FAILED
+  }
+
+  @Synchronized
+  fun disconnect() {
+    check(state == State.CONNECTED || state == State.FLUSHING) {
+      "MediaController cannot disconnect from state $state"
+    }
+    check(pendingOperations.isEmpty()) {
+      "MediaController cannot disconnect while ${pendingOperations.size} operations remain queued"
+    }
+    controller = null
+    connectionFailure = null
+    disconnectRequested = false
+    pendingOperations.clear()
+    state = State.DISCONNECTED
+  }
+
+  @Synchronized
+  fun controllerForSynchronousRead(): T? {
+    check(!disconnectRequested) {
+      "MediaController disconnect is in progress; call setupPlayer() after destroy completes"
+    }
+    return when (state) {
+      State.CONNECTING, State.FLUSHING -> null
+      State.CONNECTED -> checkNotNull(controller)
+      State.NOT_STARTED -> throw IllegalStateException(
+        "MediaController is not initialized; call setupPlayer() first"
+      )
+      State.DISCONNECTED -> throw IllegalStateException(
+        "MediaController is disconnected; call setupPlayer() before using the player"
+      )
+      State.FAILED -> throw IllegalStateException(
+        "MediaController connection failed; call setupPlayer() to retry",
+        connectionFailure,
+      )
+    }
+  }
+}
