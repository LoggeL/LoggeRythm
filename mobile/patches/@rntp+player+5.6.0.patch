+package com.doublesymmetry.trackplayer
+
+import androidx.media3.datasource.cache.Cache
+import io.mockk.every
+import io.mockk.mockk
+import java.nio.file.Files
+import org.junit.Assert.assertEquals
+import org.junit.Assert.assertFalse
+import org.junit.Assert.assertThrows
+import org.junit.Assert.assertTrue
+import org.junit.Test
+
+class AutomaticAudioCacheEvictionTest {
+  @Test
+  fun removesEveryResourceAndReportsTheCompletedCount() {
+    val resources = linkedSetOf("first", "second")
+    val cache = mockk<Cache>()
+    every { cache.keys } answers { resources.toSet() }
+    every { cache.removeResource(any()) } answers {
+      resources.remove(firstArg())
+      Unit
+    }
+
+    assertEquals(2, AutomaticAudioCacheEviction.clear(cache))
+    assertTrue(resources.isEmpty())
+  }
+
+  @Test
+  fun failsInsteadOfReportingSuccessWhenAResourceSurvives() {
+    val cache = mockk<Cache>()
+    every { cache.keys } returns setOf("stubborn")
+    every { cache.removeResource("stubborn") } returns Unit
+
+    val error = assertThrows(IllegalStateException::class.java) {
+      AutomaticAudioCacheEviction.clear(cache)
+    }
+    assertTrue(error.message.orEmpty().contains("1 resource"))
+  }
+
+  @Test
+  fun removesAStaleDirectoryWhenNoActiveCacheOwnsIt() {
+    val directory = Files.createTempDirectory("rntp-automatic-cache").toFile()
+    val nested = directory.resolve("cached.resource")
+    nested.writeText("departing account audio")
+    assertTrue(nested.exists())
+
+    AutomaticAudioCacheEviction.clearInactiveDirectory(directory)
+
+    assertFalse(directory.exists())
+  }
+}
