+package com.doublesymmetry.trackplayer.models
+
+import androidx.media3.common.Player
+import androidx.test.core.app.ApplicationProvider
+import androidx.test.ext.junit.runners.AndroidJUnit4
+import com.doublesymmetry.trackplayer.TrackPlayerModule.Companion.PLAYER_PREFS_NAME
+import kotlinx.serialization.json.JsonObject
+import kotlinx.serialization.json.JsonPrimitive
+import org.junit.Assert.assertEquals
+import org.junit.Assert.assertFalse
+import org.junit.Assert.assertNotNull
+import org.junit.Assert.assertTrue
+import org.junit.Test
+import org.junit.runner.RunWith
+
+@RunWith(AndroidJUnit4::class)
+class PlayerStateStorageInstrumentedTest {
+  @Test
+  fun androidKeystoreRoundTripProtectsAuthenticatedQueueAndProductMetadata() {
+    val context = ApplicationProvider.getApplicationContext<android.content.Context>()
+    val prefs = context.getSharedPreferences(PLAYER_PREFS_NAME, android.content.Context.MODE_PRIVATE)
+    assertTrue("Could not clear TrackPlayer test preferences", prefs.edit().clear().commit())
+    val token = "sf_session=instrumented-player-token"
+    val stableId = "context:playlist:one:0:track-1"
+    val state = PersistedPlayerState(
+      items = listOf(
+        PersistedPlayerMediaItem(
+          mediaId = "queue:1:0:track-1",
+          url = "https://example.com/track-1.mp3",
+          title = "Track 1",
+          duration = 180.0,
+          headers = mapOf("Cookie" to token),
+          extras = JsonObject(
+            mapOf(
+              "queueOrigin" to JsonPrimitive("context"),
+              "queueStableId" to JsonPrimitive(stableId),
+              "queueOriginalContextOrder" to JsonPrimitive(0),
+            ),
+          ),
+        ),
+      ),
+      activeIndex = 0,
+      positionMs = 37_000L,
+      repeatMode = Player.REPEAT_MODE_ONE,
+      shuffleEnabled = false,
+      queuePersistence = QueuePersistenceState(true, listOf(stableId)),
+    )
+
+    val storage = PlayerStateStorage()
+    storage.store(context, state)
+    val persisted = prefs.getString(PLAYER_STATE_KEY, null)
+    assertNotNull(persisted)
+    assertTrue(persisted!!.startsWith("aes-gcm-v1:"))
+    assertFalse(persisted.contains(token))
+    assertFalse(persisted.contains(stableId))
+
+    val restored = storage.load(context)
+    assertEquals(state, restored)
+  }
+}
