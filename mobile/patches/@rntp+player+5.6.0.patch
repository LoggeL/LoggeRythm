+      MediaControllerTrustPolicy.canConnect(
+        appUid,
+        appUid,
+        isTrusted = false,
+      )
+    )
+    assertTrue(
+      MediaControllerTrustPolicy.canUsePrivilegedCommands(
+        appUid,
+        appUid,
