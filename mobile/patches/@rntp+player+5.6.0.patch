+internal class BrowseTreeStorage(
+  private val encryptionKey: () -> SecretKey = { AndroidBrowseTreeKey.getOrCreate() },
+  private val decryptionKey: () -> SecretKey = { AndroidBrowseTreeKey.requireExisting() },
+) {
+  fun store(context: Context, tree: BrowseTree) {
+    val encoded = try {
+      val plaintext = Json.encodeToString(tree).toByteArray(StandardCharsets.UTF_8)
+      val cipher = Cipher.getInstance(AES_GCM)
+      cipher.init(Cipher.ENCRYPT_MODE, encryptionKey())
+      cipher.updateAAD(BROWSE_TREE_AAD)
+      val ciphertext = cipher.doFinal(plaintext)
+      listOf(
+        ENCRYPTED_PREFIX,
+        Base64.encodeToString(cipher.iv, Base64.NO_WRAP),
+        Base64.encodeToString(ciphertext, Base64.NO_WRAP),
+      ).joinToString(":")
+    } catch (cause: Exception) {
+      throw IllegalStateException(
+        "Android Auto browse tree could not be encrypted: ${cause.message}",
+        cause,
+      )
+    }
+    val prefs = context.getSharedPreferences(PLAYER_PREFS_NAME, Context.MODE_PRIVATE)
+    if (!prefs.edit().putString(BROWSE_TREE_KEY, encoded).commit()) {
+      throw IllegalStateException("Failed to persist the encrypted Android Auto browse tree")
+    }
+  }
+
+  fun clear(context: Context) {
+    val prefs = context.getSharedPreferences(PLAYER_PREFS_NAME, Context.MODE_PRIVATE)
+    if (!prefs.edit().remove(BROWSE_TREE_KEY).commit()) {
+      throw IllegalStateException("Failed to delete the persisted Android Auto browse tree")
+    }
+  }
+
+  fun load(context: Context): BrowseTree {
+    val prefs = context.getSharedPreferences(PLAYER_PREFS_NAME, Context.MODE_PRIVATE)
+    val encoded = prefs.getString(BROWSE_TREE_KEY, null) ?: return BrowseTree()
+
+    if (encoded.trimStart().startsWith("{")) {
+      val migrated = decodeJson(encoded, "legacy plaintext")
+      store(context, migrated)
+      return migrated
+    }
+
+    val parts = encoded.split(':')
+    if (parts.size != 3 || parts[0] != ENCRYPTED_PREFIX) {
+      throw IllegalStateException(
+        "Stored Android Auto browse tree has an unsupported encrypted format",
+      )
+    }
+    val plaintext = try {
+      val iv = Base64.decode(parts[1], Base64.NO_WRAP)
+      val ciphertext = Base64.decode(parts[2], Base64.NO_WRAP)
+      val cipher = Cipher.getInstance(AES_GCM)
+      cipher.init(Cipher.DECRYPT_MODE, decryptionKey(), GCMParameterSpec(128, iv))
+      cipher.updateAAD(BROWSE_TREE_AAD)
+      String(cipher.doFinal(ciphertext), StandardCharsets.UTF_8)
