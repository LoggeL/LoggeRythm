    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "12.0.1",
    "@react-native-community/slider": "5.2.0",
    "@react-native-vector-icons/material-design-icons": "13.1.2",
    "@react-navigation/bottom-tabs": "^7.18.7",
    "@react-navigation/native": "^7.3.7",
    "@react-navigation/native-stack": "^7.17.9",
    "@loggerythm/player-native": "file:modules/loggerythm-player",
    "@loggerythm/updater-native": "file:modules/loggerythm-updater",
    "@tanstack/react-query": "^5.101.2",
    "expo": "~57.0.7",
    "expo-build-properties": "~57.0.6",
    "expo-secure-store": "~57.0.1",
    "expo-status-bar": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~57.0.0",
    "sharp": "0.34.5",
    "typescript": "~6.0.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "uuid": "11.1.1"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "generate:android-icons": "node scripts/generate_android_brand_assets.mjs",
    "check:android-icons": "node scripts/generate_android_brand_assets.mjs --check",
    "check:dependency-security": "node scripts/verify_dependency_security.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:qa-tools": "python3 -m unittest discover -s scripts -p 'test_*.py'",
    "test:watch": "vitest",
    "smoke:android": "python3 scripts/android_smoke.py",
    "qa:android-release": "python3 scripts/android_smoke.py",
    "qa:android-session": "python3 scripts/android_session_qa.py",
    "qa:android-auth": "python3 scripts/android_auth_qa.py",
    "check": "npm run check:android-icons && npm run check:dependency-security && npm run typecheck && npm run lint && npm test && npm run test:qa-tools"
  },
  "private": true
}
